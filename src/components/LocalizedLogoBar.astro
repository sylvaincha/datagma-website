---
// Logo bar localisé — 6 sets de logos selon navigator.language
// Sources : CSV clients Datagma (227 entreprises uniques analysées)
---

<section class="py-10 border-y border-gray-100 bg-white/60 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <p id="logo-bar-label" class="text-center text-[11px] font-extrabold text-gray-400 uppercase tracking-widest mb-7">
      2,400+ teams worldwide added Datagma to their stack
    </p>

    <!-- EN / Global (default) -->
    <div id="logos-en" class="logo-set hidden">
      <div class="logo-row">
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data" class="logo-img h-7" />
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"    class="logo-img h-6" />
        <img src="/assets/scraped/ramp-1.png"           alt="Ramp"         class="logo-img h-7" />
        <span class="logo-word">Roche</span>
        <span class="logo-word">Akamai</span>
        <span class="logo-word">JLL</span>
        <img src="/assets/scraped/IHS_Markit_logo.svg" alt="IHS Markit"   class="logo-img h-6" />
        <span class="logo-word">HSBC</span>
      </div>
    </div>

    <!-- FR — France -->
    <div id="logos-fr" class="logo-set hidden">
      <div class="logo-row">
        <img src="/assets/scraped/lemlist-1.png"        alt="Lemlist"         class="logo-img h-6" />
        <img src="/assets/scraped/LOGO-HYPERLEX.png"    alt="Hyperlex"        class="logo-img h-6" />
        <span class="logo-word">Agicap</span>
        <span class="logo-word">Yousign</span>
        <span class="logo-word">Alexander Hughes</span>
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data"    class="logo-img h-7" />
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"       class="logo-img h-6" />
        <span class="logo-word">Flatpay</span>
      </div>
    </div>

    <!-- IT — Italie -->
    <div id="logos-it" class="logo-set hidden">
      <div class="logo-row">
        <span class="logo-word">Tecnocasa</span>
        <span class="logo-word">Tempocasa</span>
        <span class="logo-word">Amaris</span>
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data" class="logo-img h-7" />
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"    class="logo-img h-6" />
        <img src="/assets/scraped/ramp-1.png"           alt="Ramp"         class="logo-img h-7" />
        <img src="/assets/scraped/IHS_Markit_logo.svg" alt="IHS Markit"   class="logo-img h-6" />
      </div>
    </div>

    <!-- DE — Allemagne / DACH -->
    <div id="logos-de" class="logo-set hidden">
      <div class="logo-row">
        <span class="logo-word">Capgemini</span>
        <span class="logo-word">Netlight</span>
        <span class="logo-word">Roche</span>
        <img src="/assets/scraped/ramp-1.png"           alt="Ramp"         class="logo-img h-7" />
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"    class="logo-img h-6" />
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data" class="logo-img h-7" />
        <img src="/assets/scraped/IHS_Markit_logo.svg" alt="IHS Markit"   class="logo-img h-6" />
      </div>
    </div>

    <!-- NL — Pays-Bas / Belgique -->
    <div id="logos-nl" class="logo-set hidden">
      <div class="logo-row">
        <span class="logo-word">Leexi</span>
        <span class="logo-word">Lincoln</span>
        <span class="logo-word">Capgemini</span>
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"    class="logo-img h-6" />
        <img src="/assets/scraped/ramp-1.png"           alt="Ramp"         class="logo-img h-7" />
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data" class="logo-img h-7" />
        <img src="/assets/scraped/IHS_Markit_logo.svg" alt="IHS Markit"   class="logo-img h-6" />
      </div>
    </div>

    <!-- ES/PT — Espagne / Portugal / LATAM -->
    <div id="logos-es" class="logo-set hidden">
      <div class="logo-row">
        <span class="logo-word">Capgemini</span>
        <span class="logo-word">Roche</span>
        <span class="logo-word">JLL</span>
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"    class="logo-img h-6" />
        <img src="/assets/scraped/ramp-1.png"           alt="Ramp"         class="logo-img h-7" />
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data" class="logo-img h-7" />
        <img src="/assets/scraped/IHS_Markit_logo.svg" alt="IHS Markit"   class="logo-img h-6" />
      </div>
    </div>

    <!-- IN — Inde (hi / en-IN) -->
    <div id="logos-in" class="logo-set hidden">
      <div class="logo-row">
        <span class="logo-word">Swiggy</span>
        <span class="logo-word">Truecaller</span>
        <span class="logo-word">Capgemini</span>
        <span class="logo-word">HSBC</span>
        <span class="logo-word">JLL</span>
        <span class="logo-word">Kotak Life</span>
        <span class="logo-word">upGrad</span>
        <span class="logo-word">IDFC FIRST Bank</span>
      </div>
    </div>

    <!-- AU — Australie -->
    <div id="logos-au" class="logo-set hidden">
      <div class="logo-row">
        <span class="logo-word">Blinq</span>
        <span class="logo-word">Micromine</span>
        <span class="logo-word">Roche</span>
        <img src="/assets/scraped/charfelee-1.png"      alt="Chargebee"    class="logo-img h-6" />
        <img src="/assets/scraped/ramp-1.png"           alt="Ramp"         class="logo-img h-7" />
        <img src="/assets/scraped/captail-data-1.png"  alt="Captain Data" class="logo-img h-7" />
        <img src="/assets/scraped/IHS_Markit_logo.svg" alt="IHS Markit"   class="logo-img h-6" />
      </div>
    </div>

  </div>
</section>

<style>
  .logo-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }
  @media (min-width: 640px) { .logo-row { gap: 3rem; } }

  .logo-img {
    object-fit: contain;
    opacity: 0.4;
    filter: grayscale(100%);
    transition: opacity 0.25s;
    flex-shrink: 0;
  }
  .logo-img:hover { opacity: 0.65; }

  .logo-word {
    font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: -0.02em;
    color: #b0b8c4;
    white-space: nowrap;
    transition: color 0.25s;
    user-select: none;
  }
  .logo-word:hover { color: #6b7280; }
</style>

<script is:inline>
(function () {
  var labels = {
    fr: "2\u00a0400\u00a0+ équipes dans le monde font confiance à Datagma",
    it: "2.400\u00a0+ team in tutto il mondo usano Datagma",
    de: "Über 2.400 Teams weltweit vertrauen Datagma",
    es: "Más de 2.400 equipos confían en Datagma",
    pt: "Mais de 2.400 equipes confiam no Datagma",
    nl: "Meer dan 2.400 teams wereldwijd vertrouwen op Datagma",
    en: "2,400+ teams worldwide added Datagma to their stack",
  };

  var full = (navigator.language || "en").toLowerCase();
  var lang = full.split("-")[0];
  var region = full.split("-")[1] || "";

  var setId;
  if (lang === "hi" || region === "in") setId = "in";
  else if (region === "au")             setId = "au";
  else if (lang === "fr")               setId = "fr";
  else if (lang === "it")               setId = "it";
  else if (lang === "de" || lang === "gsw" || lang === "lb") setId = "de";
  else if (lang === "nl")               setId = "nl";
  else if (lang === "es" || lang === "pt") setId = "es";
  else                                  setId = "en";

  var el = document.getElementById("logos-" + setId);
  if (!el) el = document.getElementById("logos-en");
  if (el) el.classList.remove("hidden");

  var labelEl = document.getElementById("logo-bar-label");
  if (labelEl) labelEl.textContent = labels[lang] || labels["en"];
})();
</script>
