---
// Cookie consent banner + preferences modal
---

<!-- ── BANNER ───────────────────────────────────────────────────────── -->
<div id="cc-banner" class="cc-hidden fixed bottom-0 left-0 right-0 z-50 p-3 sm:p-4">
  <div class="max-w-5xl mx-auto bg-white border border-gray-200 rounded-2xl shadow-xl p-4 sm:p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">

    <div class="flex items-start gap-3 flex-1 min-w-0">
      <div class="w-9 h-9 bg-amber-100 rounded-xl flex items-center justify-center shrink-0">
        <i class="fas fa-cookie-bite text-amber-600"></i>
      </div>
      <div>
        <p class="text-sm font-extrabold text-gray-900 mb-0.5">We use cookies</p>
        <p class="text-xs text-gray-500 leading-relaxed">
          We use essential cookies for the site to work, and optional analytics cookies to improve your experience.
          See our <a href="/en/cookies" class="text-violet-600 hover:underline font-bold">Cookie Policy</a>.
        </p>
      </div>
    </div>

    <div class="flex items-center gap-2 shrink-0 flex-wrap">
      <button id="cc-btn-manage" class="px-3.5 py-2 text-xs font-bold text-gray-600 border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-colors">
        Manage preferences
      </button>
      <button id="cc-btn-reject" class="px-3.5 py-2 text-xs font-bold text-gray-600 border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-colors">
        Reject non-essential
      </button>
      <button id="cc-btn-accept" class="px-3.5 py-2 text-xs font-bold text-white bg-violet-600 rounded-xl hover:bg-violet-700 transition-colors">
        Accept all
      </button>
    </div>

  </div>
</div>

<!-- ── PREFERENCES MODAL ─────────────────────────────────────────────── -->
<div id="cc-modal" class="cc-hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-4">

  <div id="cc-overlay" class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>

  <div class="relative z-10 bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto">

    <div class="flex items-center justify-between p-5 border-b border-gray-100">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-amber-100 rounded-xl flex items-center justify-center">
          <i class="fas fa-sliders text-amber-600 text-sm"></i>
        </div>
        <h2 class="font-extrabold text-gray-900">Cookie preferences</h2>
      </div>
      <button id="cc-modal-close" class="w-8 h-8 rounded-lg text-gray-400 hover:text-gray-600 hover:bg-gray-100 flex items-center justify-center transition-colors">
        <i class="fas fa-times text-sm"></i>
      </button>
    </div>

    <div class="p-5 space-y-4">
      <p class="text-sm text-gray-500 leading-relaxed">
        Choose which cookies you allow. Your preference is stored for 6 months and can be changed at any time.
        Read our <a href="/en/cookies" class="text-violet-600 hover:underline font-bold">Cookie Policy</a> for full details.
      </p>

      <!-- Essential — always on -->
      <div class="border border-gray-200 rounded-xl p-4">
        <div class="flex items-center justify-between mb-2">
          <div>
            <p class="text-sm font-extrabold text-gray-900">Essential cookies</p>
            <p class="text-xs text-gray-400">Always active</p>
          </div>
          <div class="relative w-10 h-6">
            <div class="w-10 h-6 bg-emerald-500 rounded-full opacity-60 cursor-not-allowed"></div>
            <div class="absolute top-1 right-1 w-4 h-4 bg-white rounded-full shadow"></div>
          </div>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">
          Required for the site to function. Cannot be disabled. Includes session cookies, consent storage, and routing cookies (Cloudflare).
        </p>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">intercom-id-*</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">intercom-sessions-*</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">cookieconsent_status</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">cfmrk_cic</span>
        </div>
      </div>

      <!-- Analytics — toggle -->
      <div class="border border-gray-200 rounded-xl p-4">
        <div class="flex items-center justify-between mb-2">
          <div>
            <p class="text-sm font-extrabold text-gray-900">Analytics cookies</p>
            <p class="text-xs text-gray-400">Help us improve the site</p>
          </div>
          <label class="relative cursor-pointer">
            <input type="checkbox" id="cc-analytics-toggle" class="sr-only peer" />
            <div class="w-10 h-6 bg-gray-200 peer-checked:bg-violet-600 rounded-full transition-colors duration-200"></div>
            <div class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full shadow transition-transform duration-200 peer-checked:translate-x-4"></div>
          </label>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed mb-3">
          Used to measure traffic and understand how visitors use the site (Google Analytics, Hotjar, Segment, HubSpot). No advertising use.
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">_ga</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">_gid</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">_hjid</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">ajs_anonymous_id</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">__hstc</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">hubspotutk</span>
          <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-[10px] font-mono font-bold rounded">_gac_*</span>
        </div>
      </div>
    </div>

    <div class="p-5 border-t border-gray-100 flex flex-col sm:flex-row gap-2">
      <button id="cc-modal-reject" class="flex-1 px-4 py-2.5 text-sm font-bold text-gray-600 border border-gray-200 rounded-xl hover:bg-gray-50 transition-colors">
        Reject non-essential
      </button>
      <button id="cc-save-prefs" class="flex-1 px-4 py-2.5 text-sm font-bold text-white bg-violet-600 rounded-xl hover:bg-violet-700 transition-colors">
        Save preferences
      </button>
      <button id="cc-modal-accept" class="flex-1 px-4 py-2.5 text-sm font-bold text-white bg-emerald-600 rounded-xl hover:bg-emerald-700 transition-colors">
        Accept all
      </button>
    </div>

  </div>
</div>

<style>
  .cc-hidden { display: none !important; }
</style>

<script>
  const KEY = 'cookieconsent_status';

  function getConsent() {
    try { return JSON.parse(localStorage.getItem(KEY) ?? 'null'); } catch { return null; }
  }

  function saveConsent(analytics: boolean) {
    const val = { analytics, ts: Date.now() };
    localStorage.setItem(KEY, JSON.stringify(val));
    document.cookie = `cookieconsent_status=${analytics ? 'all' : 'essential'}; max-age=15552000; path=/; SameSite=Lax`;
  }

  function q(id: string) { return document.getElementById(id); }

  function hideBanner() { q('cc-banner')?.classList.add('cc-hidden'); }
  function showBanner() { q('cc-banner')?.classList.remove('cc-hidden'); }

  function hideModal() {
    q('cc-modal')?.classList.add('cc-hidden');
    document.body.style.overflow = '';
  }
  function showModal() {
    const toggle = q('cc-analytics-toggle') as HTMLInputElement | null;
    if (toggle) toggle.checked = getConsent()?.analytics ?? false;
    q('cc-modal')?.classList.remove('cc-hidden');
    document.body.style.overflow = 'hidden';
  }

  // Init on load
  if (!getConsent()) showBanner();

  // Banner buttons
  q('cc-btn-accept')?.addEventListener('click', () => { saveConsent(true);  hideBanner(); hideModal(); });
  q('cc-btn-reject')?.addEventListener('click', () => { saveConsent(false); hideBanner(); hideModal(); });
  q('cc-btn-manage')?.addEventListener('click', () => showModal());

  // Modal buttons
  q('cc-modal-accept')?.addEventListener('click', () => { saveConsent(true);  hideBanner(); hideModal(); });
  q('cc-modal-reject')?.addEventListener('click', () => { saveConsent(false); hideBanner(); hideModal(); });
  q('cc-modal-close')?.addEventListener('click',  hideModal);
  q('cc-overlay')?.addEventListener('click', hideModal);
  q('cc-save-prefs')?.addEventListener('click', () => {
    const toggle = q('cc-analytics-toggle') as HTMLInputElement | null;
    saveConsent(toggle?.checked ?? false);
    hideBanner();
    hideModal();
  });

  // "Manage cookies" links / buttons anywhere on the page (data-cc-manage)
  document.querySelectorAll('[data-cc-manage]').forEach(el => {
    el.addEventListener('click', (e) => { e.preventDefault(); showModal(); });
  });
</script>
