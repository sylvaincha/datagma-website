---
const {
  eyebrow = "",
  title = "",
  subtitle = "",
  ctaText = "",
  ctaHref = "",
  secondaryText = "",
  secondaryHref = "",
} = Astro.props;
---

<section class="max-w-7xl mx-auto mb-16 sm:mb-20 lg:mb-24 px-4 sm:px-6 lg:px-8">
  <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
    <div class="lg:col-span-7 relative z-10 fade-up">
      {eyebrow ? (
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white border border-gray-200 rounded-full text-sm font-bold text-gray-700 mb-8 shadow-soft-sm">
          <span class="w-2 h-2 bg-blue-600 rounded-full animate-pulse"></span>
          {eyebrow}
        </div>
      ) : null}

      <h1 class="font-display font-extrabold text-3xl sm:text-4xl md:text-5xl xl:text-6xl leading-[1.05] tracking-tight mb-6 text-gray-900">
        {title}
      </h1>

      {subtitle ? (
        <p class="text-lg sm:text-xl text-gray-600 font-medium mb-10 leading-relaxed max-w-2xl">
          {subtitle}
        </p>
      ) : null}

      {(ctaText && ctaHref) || (secondaryText && secondaryHref) ? (
        <div class="flex flex-col sm:flex-row gap-4 mb-8">
          {ctaText && ctaHref ? (
            <a href={ctaHref} class="btn btn-cta hero-cta text-base sm:text-lg">
              <span class="hero-cta__shine" aria-hidden="true"></span>
              <span class="hero-cta__content inline-flex items-center gap-2">
                {ctaText}
                <i class="fas fa-arrow-right text-xs opacity-80"></i>
              </span>
            </a>
          ) : null}

          {secondaryText && secondaryHref ? (
            <a href={secondaryHref} class="btn bg-white border border-gray-200 text-gray-700 hover:border-gray-300 hover:bg-gray-50 shadow-soft-sm text-base sm:text-lg">
              {secondaryText}
            </a>
          ) : null}
        </div>
      ) : null}
    </div>
  </div>
</section>

