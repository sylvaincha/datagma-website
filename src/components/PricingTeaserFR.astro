<script>
  const pricingData = {
    free: {
      phonesMonthly: '3 tél./mois',
      phonesAnnual:  '36 tél./an',
      emailsMonthly: '90 emails/mois',
      emailsAnnual:  '1 080 emails/an',
    },
    regular: {
      usd: { monthly: '$49', annual: '$39' },
      eur: { monthly: '€49', annual: '€39' },
      phonesMonthly: '100 tél./mois',
      phonesAnnual:  '1 200 tél./an',
      emailsMonthly: '3 000 emails/mois',
      emailsAnnual:  '36 000 emails/an',
      costUsd: { monthly: '≈ $0,49/tél.', annual: '≈ $0,39/tél.' },
      costEur: { monthly: '≈ €0,49/tél.', annual: '≈ €0,39/tél.' },
    },
    popular: {
      usd: { monthly: '$99', annual: '$79' },
      eur: { monthly: '€99', annual: '€79' },
      phonesMonthly: '250 tél./mois',
      phonesAnnual:  '3 000 tél./an',
      emailsMonthly: '7 500 emails/mois',
      emailsAnnual:  '90 000 emails/an',
      costUsd: { monthly: '≈ $0,40/tél.', annual: '≈ $0,32/tél.' },
      costEur: { monthly: '≈ €0,40/tél.', annual: '≈ €0,32/tél.' },
    },
    expert: {
      usd: { monthly: '$249', annual: '$209' },
      eur: { monthly: '€249', annual: '€209' },
      phonesMonthly: '750 tél./mois',
      phonesAnnual:  '9 000 tél./an',
      emailsMonthly: '22 500 emails/mois',
      emailsAnnual:  '270 000 emails/an',
      costUsd: { monthly: '≈ $0,33/tél.', annual: '≈ $0,28/tél.' },
      costEur: { monthly: '≈ €0,33/tél.', annual: '≈ €0,28/tél.' },
    },
  };

  let billing: 'annual' | 'monthly' = 'annual';
  let currency: 'usd' | 'eur' = 'usd';

  function render() {
    const fd = pricingData.free;
    const isAnnualFree = billing === 'annual';
    (document.getElementById('pt-phones-free') as HTMLElement).textContent = isAnnualFree ? fd.phonesAnnual : fd.phonesMonthly;
    (document.getElementById('pt-emails-free') as HTMLElement).textContent = isAnnualFree ? fd.emailsAnnual : fd.emailsMonthly;

    (['regular', 'popular', 'expert'] as const).forEach((plan) => {
      const d = pricingData[plan];
      const isAnnual = billing === 'annual';

      (document.getElementById(`pt-price-${plan}`) as HTMLElement).textContent = d[currency][billing];
      (document.getElementById(`pt-period-${plan}`) as HTMLElement).textContent = isAnnual ? '/mois · annuel' : '/mois · mensuel';
      (document.getElementById(`pt-phones-${plan}`) as HTMLElement).textContent = isAnnual ? d.phonesAnnual : d.phonesMonthly;
      (document.getElementById(`pt-emails-${plan}`) as HTMLElement).textContent = isAnnual ? d.emailsAnnual : d.emailsMonthly;
      (document.getElementById(`pt-cost-${plan}`) as HTMLElement).textContent = (currency === 'usd' ? d.costUsd : d.costEur)[billing];
    });

    const knob = document.getElementById('pt-toggle-knob') as HTMLElement;
    const monthLabel = document.getElementById('pt-monthly-label') as HTMLElement;
    const annualLabel = document.getElementById('pt-annual-label') as HTMLElement;
    const activeLabel = 'text-sm font-semibold text-blue-600 cursor-pointer select-none';
    const inactiveLabel = 'text-sm font-semibold text-gray-400 cursor-pointer select-none';

    if (billing === 'annual') {
      knob.style.transform = 'translateX(24px)';
      monthLabel.className = inactiveLabel;
      annualLabel.className = activeLabel;
    } else {
      knob.style.transform = 'translateX(0px)';
      monthLabel.className = activeLabel;
      annualLabel.className = inactiveLabel;
    }

    const activeBtn = 'text-xs font-bold px-3 py-1.5 rounded-lg border border-blue-600 bg-blue-600 text-white transition-all';
    const inactiveBtn = 'text-xs font-bold px-3 py-1.5 rounded-lg border border-gray-200 bg-white text-gray-500 hover:border-blue-400 hover:text-blue-600 transition-all';
    const usdBtn = document.getElementById('pt-usd-btn') as HTMLElement;
    const eurBtn = document.getElementById('pt-eur-btn') as HTMLElement;
    usdBtn.className = currency === 'usd' ? activeBtn : inactiveBtn;
    eurBtn.className = currency === 'eur' ? activeBtn : inactiveBtn;
  }

  document.getElementById('pt-billing-toggle')?.addEventListener('click', () => {
    billing = billing === 'annual' ? 'monthly' : 'annual';
    render();
  });

  document.getElementById('pt-monthly-label')?.addEventListener('click', () => { billing = 'monthly'; render(); });
  document.getElementById('pt-annual-label')?.addEventListener('click', () => { billing = 'annual'; render(); });
  document.getElementById('pt-usd-btn')?.addEventListener('click', () => { currency = 'usd'; render(); });
  document.getElementById('pt-eur-btn')?.addEventListener('click', () => { currency = 'eur'; render(); });

  render();
</script>
