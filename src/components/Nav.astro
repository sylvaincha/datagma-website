---
const active = Astro.props.active ?? "";

const supportedLangs = ["fr", "en", "de", "nl", "it", "es", "pt"];
const segments = Astro.url?.pathname?.split("/")?.filter(Boolean) ?? [];
const lang = supportedLangs.includes(segments[0]) ? segments[0] : "en";

const copy = {
  en: {
    emailFinder: "Email Finder",
    phoneFinder: "Phone Finder",
    chromeExt: "Chrome Extension",
    fileUpload: "File Upload",
    integrations: "Integrations",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Pricing",
    blog: "Blog",
    login: "Log in",
    startFree: "Start Free",
    menu: "Menu",
    product: "Product",
  },
  fr: {
    emailFinder: "Recherche d'email",
    phoneFinder: "Recherche de téléphone",
    chromeExt: "Extension Chrome",
    fileUpload: "Upload de fichier",
    integrations: "Intégrations",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Tarifs",
    blog: "Blog",
    login: "Se connecter",
    startFree: "Commencer gratuitement",
    menu: "Menu",
    product: "Produit",
  },
  de: {
    emailFinder: "E-Mail-Finder",
    phoneFinder: "Telefonnummer-Finder",
    chromeExt: "Chrome-Erweiterung",
    fileUpload: "Datei-Upload",
    integrations: "Integrationen",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Preise",
    blog: "Blog",
    login: "Anmelden",
    startFree: "Kostenlos starten",
    menu: "Menü",
    product: "Produkt",
  },
  nl: {
    emailFinder: "E-mailfinder",
    phoneFinder: "Telefoonfinder",
    chromeExt: "Chrome-extensie",
    fileUpload: "Bestand uploaden",
    integrations: "Integraties",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Prijzen",
    blog: "Blog",
    login: "Inloggen",
    startFree: "Gratis starten",
    menu: "Menu",
    product: "Product",
  },
  it: {
    emailFinder: "Ricerca email",
    phoneFinder: "Ricerca telefono",
    chromeExt: "Estensione Chrome",
    fileUpload: "Upload file",
    integrations: "Integrazioni",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Prezzi",
    blog: "Blog",
    login: "Accedi",
    startFree: "Inizia gratis",
    menu: "Menu",
    product: "Prodotto",
  },
  es: {
    emailFinder: "Buscador de email",
    phoneFinder: "Buscador de teléfono",
    chromeExt: "Extensión Chrome",
    fileUpload: "Subida de archivos",
    integrations: "Integraciones",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Precios",
    blog: "Blog",
    login: "Iniciar sesión",
    startFree: "Empezar gratis",
    menu: "Menú",
    product: "Producto",
  },
  pt: {
    emailFinder: "Pesquisa de email",
    phoneFinder: "Pesquisa de telefone",
    chromeExt: "Extensão Chrome",
    fileUpload: "Upload de ficheiro",
    integrations: "Integrações",
    zapier: "Zapier / Make / n8n",
    clay: "Clay",
    api: "API",
    pricing: "Preços",
    blog: "Blog",
    login: "Entrar",
    startFree: "Começar grátis",
    menu: "Menu",
    product: "Produto",
  },
};

const t = copy[lang] || copy.en;

// Build lang-aware URLs
const langPrefix = lang === "en" ? "/en" : `/${lang}`;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-200/70 shadow-soft-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={`${langPrefix}/home`} class="flex items-center gap-2.5 font-display font-bold text-lg sm:text-xl tracking-tight text-gray-900 hover:opacity-80 transition-opacity">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center transition-transform">
          <span class="text-white font-extrabold text-sm">D</span>
        </div>
        Datagma
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-1">

        <!-- Product dropdown -->
        <div class="relative group">
          <button class="inline-flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-3 py-2 rounded-xl font-semibold text-sm">
            {t.product}
            <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-64 rounded-2xl p-2 shadow-soft-lg bg-white border border-gray-200/70 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <a href={`${langPrefix}/email-finder`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-envelope text-blue-500 w-4"></i>{t.emailFinder}
            </a>
            <a href={`${langPrefix}/phone-finder`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-phone text-green-500 w-4"></i>{t.phoneFinder}
            </a>
            <a href={`${langPrefix}/chrome-extension`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fab fa-chrome text-blue-400 w-4"></i>{t.chromeExt}
            </a>
            <a href={`${langPrefix}/file-upload`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-file-upload text-green-500 w-4"></i>{t.fileUpload}
            </a>
            <a href={`${langPrefix}/api`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-plug text-gray-500 w-4"></i>{t.api}
            </a>
          </div>
        </div>

        <!-- Integrations dropdown -->
        <div class="relative group">
          <button class="inline-flex items-center gap-2 text-gray-600 hover:text-blue-600 transition-colors px-3 py-2 rounded-xl font-semibold text-sm">
            {t.integrations}
            <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-52 rounded-2xl p-2 shadow-soft-lg bg-white border border-gray-200/70 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            <a href={`${langPrefix}/clay`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-layer-group text-orange-500 w-4"></i>{t.clay}
            </a>
            <a href={`${langPrefix}/zapier`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-link text-orange-400 w-4"></i>{t.zapier}
            </a>
            <a href={`${langPrefix}/api`} class="px-3 py-2 rounded-xl font-semibold text-gray-700 hover:bg-white/60 hover:text-blue-600 transition-colors text-sm flex items-center gap-2.5 w-full">
              <i class="fas fa-code text-gray-500 w-4"></i>{t.api}
            </a>
          </div>
        </div>

        <a href={`${langPrefix}/pricing`} class={`px-3 py-2 rounded-xl font-semibold text-sm transition-colors ${active === 'pricing' ? 'text-blue-600 bg-blue-50' : 'text-gray-600 hover:text-blue-600'}`}>{t.pricing}</a>
        <a href={`/${lang}/blog`} class={`px-3 py-2 rounded-xl font-semibold text-sm transition-colors ${active === 'blog' ? 'text-blue-600 bg-blue-50' : 'text-gray-600 hover:text-blue-600'}`}>{t.blog}</a>
      </div>

      <!-- Right CTA -->
      <div class="hidden md:flex items-center gap-3">

        <!-- Language selector — compact globe dropdown -->
        <div class="relative group">
          <button
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gray-200 bg-white text-sm font-semibold text-gray-600 hover:border-blue-300 hover:text-blue-600 transition-colors cursor-pointer"
            aria-label="Language"
          >
            <svg class="w-3.5 h-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/>
            </svg>
            <span class="uppercase tracking-wide text-[11px] font-extrabold">{lang}</span>
            <svg class="w-3 h-3 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full right-0 mt-2 w-40 rounded-2xl p-1.5 shadow-soft-lg bg-white border border-gray-200/70 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
            {[
              { code: "en", label: "English" },
              { code: "fr", label: "Français" },
              { code: "de", label: "Deutsch" },
              { code: "nl", label: "Nederlands" },
              { code: "it", label: "Italiano" },
              { code: "es", label: "Español" },
              { code: "pt", label: "Português" },
            ].map((l) => {
              const page = segments[1] ?? "home";
              return (
                <a
                  href={`/${l.code}/${page}`}
                  class={`flex items-center gap-2.5 px-3 py-2 rounded-xl text-sm font-semibold transition-colors ${lang === l.code ? 'text-blue-600 bg-blue-50' : 'text-gray-700 hover:bg-gray-50 hover:text-blue-600'}`}
                >
                  <span class="text-[10px] font-extrabold uppercase tracking-wider w-6 text-gray-400">{l.code}</span>
                  {l.label}
                </a>
              );
            })}
          </div>
        </div>

        <a href="https://app.datagma.com/login" class="text-sm font-bold text-gray-600 hover:text-gray-900 hidden sm:block whitespace-nowrap">{t.login}</a>
        <a href="https://app.datagma.com/register" class="btn-primary px-4 sm:px-5 py-2 sm:py-2.5 rounded-full text-sm whitespace-nowrap">{t.startFree}</a>
      </div>

      <!-- Mobile menu button -->
      <button id="menu-btn" class="md:hidden inline-flex items-center px-3 py-2 rounded-full border border-gray-200 text-gray-600 hover:text-blue-600 hover:border-blue-400 transition-colors" aria-label={t.menu}>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white px-4 py-4 space-y-1">
    <a href={`${langPrefix}/email-finder`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.emailFinder}</a>
    <a href={`${langPrefix}/phone-finder`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.phoneFinder}</a>
    <a href={`${langPrefix}/chrome-extension`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.chromeExt}</a>
    <a href={`${langPrefix}/file-upload`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.fileUpload}</a>
    <a href={`${langPrefix}/zapier`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.zapier}</a>
    <a href={`${langPrefix}/api`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.api}</a>
    <a href={`${langPrefix}/pricing`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.pricing}</a>
    <a href={`/${lang}/blog`} class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50">{t.blog}</a>
    <div class="pt-2 flex flex-col gap-2">
      <a href="https://app.datagma.com/login" class="block px-3 py-2 rounded-xl text-sm font-semibold text-gray-700 hover:bg-gray-50 text-center">{t.login}</a>
      <a href="https://app.datagma.com/register" class="btn-primary px-4 py-2.5 rounded-full text-sm text-center">{t.startFree}</a>
    </div>
  </div>
</nav>
