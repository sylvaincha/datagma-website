---
// DemoWidget — live demo with two separate sections: Phone Finder & Email Finder
// Cloudflare Turnstile (invisible mode) protects against bots & datacenter IPs.
// PUBLIC_TURNSTILE_SITE_KEY must be set in Vercel env (public).
// Falls back to CF test key (always-passes) if not set.
const TURNSTILE_SITE_KEY = (import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "1x00000000000000000000AA").trim();
---

<section class="py-20 relative overflow-hidden">

  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-25"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-sky-100 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 text-xs font-bold px-4 py-1.5 rounded-full mb-4">
        <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
        Live demo — no account needed
      </div>
      <h2 class="font-display font-extrabold text-3xl sm:text-4xl text-gray-900 mb-3 tracking-tight">
        Try it yourself — real data, right now
      </h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        Find direct mobiles or work emails.<br/>No credit card. Results in seconds.
      </p>
    </div>

    <div class="relative overflow-hidden rounded-3xl bg-white border border-gray-200/80 shadow-[0_20px_60px_rgba(37,99,235,.1),0_4px_20px_rgba(0,0,0,.06)]">

      <!-- Top gradient bar -->
      <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-blue-500 via-sky-400 to-blue-600"></div>

      <div class="p-6 sm:p-8">

        <!-- ── Main tabs: Phone / Email ───────────────────────────── -->
        <div class="flex gap-2 mb-7 p-1 bg-gray-100 rounded-2xl">
          <button id="main-tab-phone"
            class="main-tab flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-bold transition-all"
            data-panel="phone-panel">
            <i class="fas fa-mobile-alt"></i>
            Phone Finder
          </button>
          <button id="main-tab-email"
            class="main-tab flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-sm font-bold transition-all"
            data-panel="email-panel">
            <i class="fas fa-envelope"></i>
            Email Finder
          </button>
        </div>

        <!-- ══════════════════════════════════════════════════════════
             PHONE PANEL
        ═══════════════════════════════════════════════════════════ -->
        <div id="phone-panel" class="panel-content">

          <!-- Sub-tabs -->
          <div class="grid grid-cols-3 gap-1.5 mb-5 bg-gray-50 rounded-xl p-1.5">
            {[
              { id: "linkedin",    label: "LinkedIn URL",   icon: "fab fa-linkedin" },
              { id: "nameCompany", label: "Name + Company", icon: "fas fa-building" },
              { id: "nameDomain",  label: "Name + Domain",  icon: "fas fa-globe"    },
            ].map((tab) => (
              <button
                class="phone-subtab flex items-center justify-center gap-1.5 px-2 py-2 rounded-lg text-xs font-bold transition-all text-center leading-tight"
                data-mode={tab.id}
              >
                <i class={`${tab.icon} text-[10px]`}></i>
                {tab.label}
              </button>
            ))}
          </div>

          <form id="phone-form" class="space-y-3">

            <!-- LinkedIn -->
            <div class="phone-inputs" data-for="linkedin">
              <input type="url" name="linkedin"
                placeholder="https://linkedin.com/in/firstname-lastname"
                class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-white placeholder-gray-400" />
            </div>

            <!-- Name + Company -->
            <div class="phone-inputs hidden" data-for="nameCompany">
              <div class="grid sm:grid-cols-2 gap-3">
                <input type="text" name="fullNameC" placeholder="Full name (e.g. John Smith)"
                  class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-white placeholder-gray-400" />
                <input type="text" name="companyName" placeholder="Company (e.g. Stripe)"
                  class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-white placeholder-gray-400" />
              </div>
            </div>

            <!-- Name + Domain -->
            <div class="phone-inputs hidden" data-for="nameDomain">
              <div class="grid sm:grid-cols-2 gap-3">
                <input type="text" name="fullNameD" placeholder="Full name (e.g. John Smith)"
                  class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-white placeholder-gray-400" />
                <input type="text" name="domain" placeholder="Domain (e.g. stripe.com)"
                  class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-white placeholder-gray-400" />
              </div>
            </div>

            <button id="phone-submit" type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all shadow-md shadow-blue-200 flex items-center justify-center gap-2 text-sm">
              <i class="fas fa-mobile-alt text-xs"></i>
              <span id="phone-btn-text">Find direct mobile</span>
            </button>
          </form>

          <!-- Credits -->
          <div class="mt-3 text-[11px] text-gray-400 font-semibold text-center">
            <i class="fas fa-mobile-alt mr-1 text-blue-400"></i>
            <span id="phones-remaining">3</span> phone searches left today
            <span class="mx-2 text-gray-200">·</span>
            Phones shown masked — register to see full numbers
          </div>

          <!-- Phone error -->
          <div id="phone-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-2xl text-sm text-red-700 font-medium flex items-center gap-2">
            <i class="fas fa-exclamation-circle text-red-400 shrink-0"></i>
            <span id="phone-error-msg">An error occurred.</span>
          </div>

          <!-- Phone result -->
          <div id="phone-result" class="hidden mt-5">
            <div class="rounded-2xl border border-gray-200 bg-gray-50/50 overflow-hidden">

              <!-- Contact header — hidden when person not found -->
              <div id="p-contact-header" class="flex items-center gap-4 p-5 bg-white border-b border-gray-100">
                <div id="p-avatar" class="w-11 h-11 rounded-xl bg-gradient-to-br from-blue-500 to-sky-600 flex items-center justify-center text-white font-extrabold text-sm shrink-0">?</div>
                <div class="min-w-0">
                  <div id="p-name" class="font-display font-bold text-gray-900 text-base leading-tight"></div>
                  <div id="p-role" class="text-gray-500 text-xs mt-0.5 truncate"></div>
                </div>
                <span id="p-found-badge" class="ml-auto shrink-0 text-[10px] font-extrabold text-green-700 bg-green-50 border border-green-200 px-2.5 py-1 rounded-full hidden">
                  <i class="fas fa-check-circle mr-1"></i>Found
                </span>
              </div>

              <!-- Phone data -->
              <div class="p-5 space-y-3">

                <!-- Phones (rendered dynamically) -->
                <div id="p-phones-container" class="hidden space-y-2.5"></div>

                <!-- Case A : person not found at all -->
                <div id="p-person-not-found" class="hidden">
                  <div class="p-5 bg-gray-50 border border-gray-200 rounded-xl">
                    <div class="flex items-center gap-3 mb-4">
                      <div class="w-10 h-10 bg-gray-200 rounded-xl flex items-center justify-center shrink-0">
                        <i class="fas fa-user-slash text-gray-500 text-base"></i>
                      </div>
                      <div>
                        <div class="text-sm font-bold text-gray-800">Person not found</div>
                        <div class="text-xs text-gray-500 mt-0.5">Check the spelling of the name, or try a different search method.</div>
                      </div>
                    </div>
                    <div class="text-[10px] font-extrabold text-gray-400 uppercase tracking-wider mb-2">Try another method:</div>
                    <div class="flex flex-wrap gap-2">
                      <button class="p-try-method text-xs font-bold px-3 py-2 rounded-lg bg-white border border-gray-200 hover:border-blue-400 hover:text-blue-600 transition-colors text-gray-600" data-mode="linkedin">
                        <i class="fab fa-linkedin mr-1.5 text-[11px]"></i>LinkedIn URL
                      </button>
                      <button class="p-try-method text-xs font-bold px-3 py-2 rounded-lg bg-white border border-gray-200 hover:border-blue-400 hover:text-blue-600 transition-colors text-gray-600" data-mode="nameCompany">
                        <i class="fas fa-building mr-1.5 text-[11px]"></i>Name + Company
                      </button>
                      <button class="p-try-method text-xs font-bold px-3 py-2 rounded-lg bg-white border border-gray-200 hover:border-blue-400 hover:text-blue-600 transition-colors text-gray-600" data-mode="nameDomain">
                        <i class="fas fa-globe mr-1.5 text-[11px]"></i>Name + Domain
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Case B : person found, but no direct mobile indexed -->
                <div id="p-no-phone" class="hidden">
                  <div class="p-4 bg-amber-50 border border-amber-200 rounded-xl space-y-3">
                    <div class="flex items-start gap-2.5">
                      <i class="fas fa-mobile-alt text-amber-500 shrink-0 mt-0.5 text-sm"></i>
                      <div>
                        <div class="text-xs font-bold text-gray-800 mb-1">Contact found — no direct mobile indexed</div>
                        <div id="p-no-phone-msg" class="text-[11px] text-gray-500 leading-relaxed">No direct mobile in standard index. Run a deep search to scan extended sources.</div>
                      </div>
                    </div>
                    <button id="p-deep-search-btn"
                      class="w-full flex items-center justify-center gap-2 py-2.5 px-4 bg-blue-600 hover:bg-blue-700 disabled:opacity-60 disabled:cursor-not-allowed text-white text-xs font-bold rounded-xl transition-colors shadow-sm shadow-blue-200">
                      <i class="fas fa-search-plus text-[11px]"></i>
                      <span id="p-deep-search-txt">Run deep search</span>
                    </button>
                  </div>
                </div>
              </div>

              <!-- CTA footer -->
              <div class="px-5 py-4 bg-blue-50/50 border-t border-blue-100 flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs text-gray-500 font-semibold">
                  <i class="fas fa-lock mr-1 text-blue-400"></i>Register free — 3 phones/month included
                </div>
                <a href="https://app.datagma.com/register"
                  class="shrink-0 bg-blue-600 text-white font-bold px-5 py-2 rounded-xl text-xs hover:bg-blue-700 transition-colors shadow-md shadow-blue-200">
                  Create free account →
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════
             EMAIL PANEL
        ═══════════════════════════════════════════════════════════ -->
        <div id="email-panel" class="panel-content hidden">

          <form id="email-form" class="space-y-3">
            <div class="grid sm:grid-cols-2 gap-3">
              <input type="text" name="emailFullName" placeholder="Full name (e.g. John Smith)"
                class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-violet-400 focus:border-transparent bg-white placeholder-gray-400" />
              <input type="text" name="companyOrDomain" placeholder="Domain (e.g. stripe.com)"
                class="demo-input w-full px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-violet-400 focus:border-transparent bg-white placeholder-gray-400" />
            </div>

            <button id="email-submit" type="submit"
              class="w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all shadow-md shadow-violet-200 flex items-center justify-center gap-2 text-sm">
              <i class="fas fa-envelope text-xs"></i>
              <span id="email-btn-text">Find work email</span>
            </button>
          </form>

          <!-- Credits -->
          <div class="mt-3 text-[11px] text-gray-400 font-semibold text-center">
            <i class="fas fa-envelope mr-1 text-violet-400"></i>
            <span id="emails-remaining">10</span> email searches left today
            <span class="mx-2 text-gray-200">·</span>
            Only verified emails are billed
          </div>

          <!-- Email error -->
          <div id="email-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-2xl text-sm text-red-700 font-medium flex items-center gap-2">
            <i class="fas fa-exclamation-circle text-red-400 shrink-0"></i>
            <span id="email-error-msg">An error occurred.</span>
          </div>

          <!-- Email result -->
          <div id="email-result" class="hidden mt-5">
            <div class="rounded-2xl border border-gray-200 bg-gray-50/50 overflow-hidden">

              <!-- Contact header -->
              <div class="flex items-center gap-4 p-5 bg-white border-b border-gray-100">
                <div id="e-avatar" class="w-11 h-11 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-white font-extrabold text-sm shrink-0">?</div>
                <div class="min-w-0">
                  <div id="e-name" class="font-display font-bold text-gray-900 text-base leading-tight"></div>
                  <div id="e-company" class="text-gray-500 text-xs mt-0.5"></div>
                </div>
              </div>

              <!-- Email data -->
              <div class="p-5 space-y-3">

                <!-- Email found (verified) -->
                <div id="e-email-verified" class="hidden flex items-center gap-3">
                  <div class="w-9 h-9 bg-violet-50 rounded-xl flex items-center justify-center shrink-0">
                    <i class="fas fa-envelope text-violet-600 text-sm"></i>
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2 mb-0.5">
                      <div class="text-[10px] font-bold text-gray-400 uppercase tracking-wider">Work email</div>
                      <span class="text-[9px] font-extrabold text-green-700 bg-green-50 border border-green-200 px-1.5 py-0.5 rounded-full">
                        <i class="fas fa-check-circle mr-0.5"></i>Verified
                      </span>
                    </div>
                    <div id="e-email-value" class="font-mono text-base font-bold text-gray-900 truncate"></div>
                  </div>
                </div>

                <!-- Email probable (not verified, free) -->
                <div id="e-email-probable" class="hidden flex items-start gap-3 p-3 bg-amber-50 border border-amber-200 rounded-xl">
                  <i class="fas fa-exclamation-triangle text-amber-500 shrink-0 mt-0.5"></i>
                  <div class="min-w-0">
                    <div class="text-xs font-bold text-gray-800 mb-0.5">Most probable email (catchall domain — not verified)</div>
                    <div id="e-probable-value" class="font-mono text-sm text-gray-700 truncate"></div>
                    <div class="text-[10px] text-gray-400 mt-1">Not billed · Test with caution before sending</div>
                  </div>
                </div>

                <!-- Not found -->
                <div id="e-email-none" class="hidden">
                  <div class="p-4 bg-amber-50 border border-amber-200 rounded-xl">
                    <div class="flex items-start gap-2.5">
                      <i class="fas fa-info-circle text-amber-500 shrink-0 mt-0.5 text-sm"></i>
                      <div>
                        <div class="text-xs font-bold text-gray-800 mb-1">No verified email found in demo</div>
                        <div class="text-[11px] text-gray-500 leading-relaxed">
                          Double-check the domain (e.g. <em>stripe.com</em> not <em>stripe.co</em>).
                          The full account searches additional sources and may return a <strong>probable email</strong> even for catchall domains.
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

              </div>

              <!-- CTA footer -->
              <div class="px-5 py-4 bg-violet-50/50 border-t border-violet-100 flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="text-xs text-gray-500 font-semibold">
                  <i class="fas fa-lock mr-1 text-violet-400"></i>Register free — 90 emails/month included
                </div>
                <a href="https://app.datagma.com/register"
                  class="shrink-0 bg-violet-600 text-white font-bold px-5 py-2 rounded-xl text-xs hover:bg-violet-700 transition-colors shadow-md shadow-violet-200">
                  Create free account →
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Turnstile container — fixed off-screen, NOT display:none (CF requires DOM visibility) -->
      <div id="cf-turnstile-container"
        style="position:fixed;top:-200px;left:-200px;width:300px;height:65px;overflow:hidden;opacity:0;pointer-events:none;"
        aria-hidden="true"></div>

    </div>
  </div>
</section>

<!-- Cloudflare Turnstile — loaded explicitly so we control the lifecycle -->
<script
  src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
  async defer
  data-sitekey={TURNSTILE_SITE_KEY}
  id="cf-turnstile-script"
></script>

<script>
(function () {
  var TOKEN_URL  = "/api/demo-token";
  var ENRICH_URL = "/api/demo-enrich";

  var cachedToken    = null;
  var tokenExpiry    = 0;
  var cfToken        = null;   // current Turnstile token (single-use)
  var cfError        = null;   // last Turnstile error code (for debug)
  var cfWidgetId     = null;   // Turnstile widget handle for reset
  var cfReady        = false;  // true once Turnstile has verified once
  var visitorId      = null;   // FingerprintJS stable browser ID

  // ── FingerprintJS — load async, fail silently ────────────────────────────
  // Uses the free open-source build from CDN (no API key needed).
  // visitorId is stable across sessions for the same browser — lets us
  // rate-limit per device even when proxies rotate IPs.
  var _fpPromise = import("https://openfpcdn.io/fingerprintjs/v4/esm/index.js")
    .then(function (FingerprintJS) { return FingerprintJS.load(); })
    .catch(function () { return null; });

  _fpPromise.then(function (fp) {
    if (!fp) return;
    fp.get().then(function (result) { visitorId = result.visitorId; });
  });

  // ── Turnstile init — called when CF script loads ─────────────────────────
  // We expose this on window so the CF script's onload can call it.
  // The CF script has render=explicit, so we call turnstile.render() ourselves.
  function initTurnstile() {
    var container = document.getElementById("cf-turnstile-container");
    var script    = document.getElementById("cf-turnstile-script");
    if (!container || !script || typeof window.turnstile === "undefined") return;

    var siteKey = (script.dataset.sitekey || "1x00000000000000000000AA").trim();

    cfWidgetId = window.turnstile.render(container, {
      sitekey:   siteKey,
      theme:     "light",
      execution: "execute",
      callback: function (token) {
        console.log("[Turnstile] token received ✓");
        cfToken = token;
        cfReady = true;
      },
      "expired-callback": function () {
        console.log("[Turnstile] token expired — resetting");
        cfToken = null;
        cfReady = false;
        if (cfWidgetId !== null) window.turnstile.reset(cfWidgetId);
      },
      "error-callback": function (code) {
        console.warn("[Turnstile] error code:", code,
          "— hostname not allowed? Check CF widget settings.");
        cfToken = null;
        cfReady = false;
        cfError = code || "unknown";
      },
      "before-interactive-callback": function () {
        console.log("[Turnstile] showing interactive challenge");
      },
    });

    console.log("[Turnstile] rendered, widgetId:", cfWidgetId, "sitekey:", siteKey.slice(0,10) + "…");
    // Trigger the challenge immediately
    if (cfWidgetId !== null) window.turnstile.execute(cfWidgetId);
  }

  // Turnstile calls window.onTurnstileLoad when the JS is ready (we set onload param)
  // But since we use render=explicit + defer, we poll until window.turnstile exists.
  (function waitForTurnstile() {
    if (typeof window.turnstile !== "undefined") {
      initTurnstile();
    } else {
      setTimeout(waitForTurnstile, 200);
    }
  })();

  // ── Get Turnstile token — waits up to 10s, re-triggers execute() if needed ──
  function getCfToken() {
    return new Promise(function (resolve) {
      if (cfToken) { resolve(cfToken); return; }
      // Re-trigger the challenge in case it hasn't fired yet
      if (cfWidgetId !== null && typeof window.turnstile !== "undefined") {
        try { window.turnstile.execute(cfWidgetId); } catch (_) {}
      }
      var waited = 0;
      var iv = setInterval(function () {
        waited += 200;
        if (cfToken) {
          clearInterval(iv); resolve(cfToken);
        } else if (waited >= 10000) {
          clearInterval(iv);
          resolve(null); // timeout after 10s — server will block; user sees friendly error
        }
      }, 200);
    });
  }

  // Reset Turnstile after each search (tokens are single-use)
  function resetTurnstile() {
    cfToken = null;
    cfReady = false;
    if (cfWidgetId !== null && typeof window.turnstile !== "undefined") {
      window.turnstile.reset(cfWidgetId);
    }
  }

  // ── HMAC Token ───────────────────────────────────────────────────────────────
  async function getToken() {
    if (cachedToken && Date.now() < tokenExpiry - 5000) return cachedToken;
    try {
      var r = await fetch(TOKEN_URL);
      if (!r.ok) throw new Error("token_error");
      var d = await r.json();
      cachedToken = d.token;
      tokenExpiry = Date.now() + (d.expiresIn || 300) * 1000;
      return cachedToken;
    } catch (_) { return null; }
  }

  // ── Helpers ─────────────────────────────────────────────────────────────────
  function q(id) { return document.getElementById(id); }
  function show(id) { var el = q(id); if (el) el.classList.remove("hidden"); }
  function hide(id) { var el = q(id); if (el) el.classList.add("hidden"); }
  function setText(id, txt) { var el = q(id); if (el) el.textContent = txt; }

  // ── Main tab switching ───────────────────────────────────────────────────────
  var mainTabs = document.querySelectorAll(".main-tab");
  mainTabs.forEach(function (btn) {
    btn.addEventListener("click", function () {
      var panelId = btn.dataset.panel;
      mainTabs.forEach(function (b) {
        var active = b.dataset.panel === panelId;
        b.classList.remove("bg-white", "text-blue-600", "shadow-sm", "text-gray-500", "text-violet-600");
        if (active) {
          b.classList.add("bg-white", "shadow-sm");
          b.classList.add(panelId === "phone-panel" ? "text-blue-600" : "text-violet-600");
        } else {
          b.classList.add("text-gray-500");
        }
      });
      document.querySelectorAll(".panel-content").forEach(function (p) {
        p.classList.toggle("hidden", p.id !== panelId);
      });
      // Reset results
      hide("phone-result"); hide("phone-error");
      hide("email-result"); hide("email-error");
    });
  });
  // Init active state
  (function () {
    var phoneTab = q("main-tab-phone");
    if (phoneTab) { phoneTab.classList.add("bg-white", "text-blue-600", "shadow-sm"); }
    var emailTab = q("main-tab-email");
    if (emailTab) { emailTab.classList.add("text-gray-500"); }
  })();

  // ── Phone sub-tab switching ──────────────────────────────────────────────────
  var phoneMode = "linkedin";
  var phoneSubtabs = document.querySelectorAll(".phone-subtab");
  var phoneInputGroups = document.querySelectorAll(".phone-inputs");

  function setPhoneSubtab(mode) {
    phoneMode = mode;
    phoneSubtabs.forEach(function (t) {
      var active = t.dataset.mode === mode;
      t.classList.remove("bg-white", "text-blue-600", "shadow-sm", "text-gray-500");
      if (active) { t.classList.add("bg-white", "text-blue-600", "shadow-sm"); }
      else { t.classList.add("text-gray-500"); }
    });
    phoneInputGroups.forEach(function (g) {
      g.classList.toggle("hidden", g.dataset.for !== mode);
    });
    hide("phone-result"); hide("phone-error");
  }
  phoneSubtabs.forEach(function (t) {
    t.addEventListener("click", function () { setPhoneSubtab(t.dataset.mode); });
  });
  setPhoneSubtab("linkedin");

  // ── Loading state helpers ────────────────────────────────────────────────────
  function setPhoneLoading(on) {
    var btn = q("phone-submit"); var txt = q("phone-btn-text");
    if (!btn || !txt) return;
    btn.disabled = on;
    txt.textContent = on ? "Searching…" : "Find direct mobile";
    if (on) { btn.classList.add("opacity-60", "cursor-not-allowed"); }
    else    { btn.classList.remove("opacity-60", "cursor-not-allowed"); }
  }
  function setEmailLoading(on) {
    var btn = q("email-submit"); var txt = q("email-btn-text");
    if (!btn || !txt) return;
    btn.disabled = on;
    txt.textContent = on ? "Searching…" : "Find work email";
    if (on) { btn.classList.add("opacity-60", "cursor-not-allowed"); }
    else    { btn.classList.remove("opacity-60", "cursor-not-allowed"); }
  }

  // ── Phone form ───────────────────────────────────────────────────────────────
  var phoneSearchHint = null; // stores form inputs as fallback for display
  var phoneForm = q("phone-form");
  if (phoneForm) {
    phoneForm.addEventListener("submit", async function (e) {
      e.preventDefault();
      hide("phone-error"); hide("phone-result"); show("p-contact-header");
      setPhoneLoading(true);

      var token = await getToken();
      if (!token) {
        show("phone-error"); setText("phone-error-msg", "Could not initialize demo. Please refresh.");
        setPhoneLoading(false); return;
      }

      var cf = await getCfToken();
      var params = new URLSearchParams({ t: token, mode: phoneMode });

      if (phoneMode === "linkedin") {
        var li = ((phoneForm.querySelector("[name=linkedin]") || {}).value || "").trim();
        if (!li) { show("phone-error"); setText("phone-error-msg", "Please enter a LinkedIn URL."); setPhoneLoading(false); return; }
        params.set("linkedin", li);
        // Try to extract name from LinkedIn handle (e.g. "adrienne-charmet" → "Adrienne Charmet")
        var handle = li.replace(/.*\/in\//i, "").replace(/[/?#].*/,"").replace(/\/$/, "");
        var parts = handle.split("-");
        var guessedName = parts.length > 1
          ? parts.map(function(p){ return p.charAt(0).toUpperCase() + p.slice(1); }).join(" ")
          : null;
        phoneSearchHint = { mode: "linkedin", linkedin: li, name: guessedName, handle: handle };
      } else if (phoneMode === "nameCompany") {
        var fn = ((phoneForm.querySelector("[name=fullNameC]") || {}).value || "").trim();
        var cn = ((phoneForm.querySelector("[name=companyName]") || {}).value || "").trim();
        if (!fn || !cn) { show("phone-error"); setText("phone-error-msg", "Please enter both full name and company."); setPhoneLoading(false); return; }
        params.set("fullName", fn); params.set("companyName", cn);
        phoneSearchHint = { mode: "nameCompany", name: fn, company: cn };
      } else if (phoneMode === "nameDomain") {
        var fn2 = ((phoneForm.querySelector("[name=fullNameD]") || {}).value || "").trim();
        var dom = ((phoneForm.querySelector("[name=domain]") || {}).value || "").trim();
        if (!fn2 || !dom) { show("phone-error"); setText("phone-error-msg", "Please enter both full name and domain."); setPhoneLoading(false); return; }
        params.set("fullName", fn2); params.set("domain", dom);
        phoneSearchHint = { mode: "nameDomain", name: fn2, domain: dom };
      }

      if (cf) params.set("cf", cf);
      if (visitorId) params.set("fid", visitorId);

      try {
        var resp = await fetch(ENRICH_URL + "?" + params.toString());
        var json = await resp.json();

        if (resp.status === 403 && json && json.error === "bot_detected") {
          show("phone-error"); setText("phone-error-msg", "Security check failed. Please wait a moment and try again.");
        } else if (resp.status === 429 || resp.status === 402) {
          showRateLimit("phone");
        } else if (resp.status === 401) {
          cachedToken = null; show("phone-error"); setText("phone-error-msg", "Session expired — please refresh the page and try again.");
        } else if (resp.status === 404) {
          // Person completely not found in Datagma's DB
          renderPhoneResult({ phone: null, found: false, contact: {} });
        } else if (!resp.ok) {
          show("phone-error"); setText("phone-error-msg", "Search failed. Please try again in a few seconds.");
        } else {
          renderPhoneResult(json);
        }
      } catch (_) {
        show("phone-error"); setText("phone-error-msg", "Network error — please check your connection and try again.");
      }
      resetTurnstile();
      setPhoneLoading(false);
    });
  }

  function renderPhoneResult(data) {
    var contact = data.contact || {};
    var hint = phoneSearchHint || {};

    // Name: API → hint.name (from form input or guessed from LinkedIn handle)
    var name = contact.fullName
      || hint.name
      || null;

    // Company/role: API → hint company/domain as fallback
    var company  = contact.company  || hint.company || hint.domain || null;
    var jobTitle = contact.jobTitle || null;
    var role = [jobTitle, company].filter(Boolean).join(" · ");

    // Avatar: initials if name known, otherwise user icon
    var av = q("p-avatar");
    if (av) {
      if (name) {
        var words    = name.trim().split(/\s+/);
        var initials = words.map(function(p){return p[0]||"";}).join("").slice(0,2).toUpperCase();
        av.innerHTML = "";
        av.textContent = initials || "?";
      } else {
        av.innerHTML = '<i class="fas fa-user text-white text-sm"></i>';
      }
    }

    // Name display: real name → LinkedIn handle (mono) → generic
    var nameEl = q("p-name");
    if (nameEl) {
      if (name) {
        nameEl.textContent = name;
        nameEl.className = "font-display font-bold text-gray-900 text-base leading-tight";
      } else if (hint.handle) {
        nameEl.textContent = hint.handle;
        nameEl.className = "font-mono text-sm text-gray-500 leading-tight";
      } else {
        nameEl.textContent = "";
      }
    }

    setText("p-role", role);

    if (data.credits && data.credits.phonesRemaining !== undefined) {
      setText("phones-remaining", data.credits.phonesRemaining);
    }

    hide("p-phones-container"); hide("p-person-not-found"); hide("p-no-phone"); hide("p-found-badge");

    var allPhones = data.phones || (data.phone ? [data.phone] : []);

    if (allPhones.length > 0) {
      // Phone(s) found ✓ — render each number
      show("p-contact-header");
      show("p-found-badge");

      var container = q("p-phones-container");
      if (container) {
        container.innerHTML = "";
        allPhones.forEach(function(ph, idx) {
          var label = idx === 0 ? "Direct mobile" : "Additional mobile";
          var row   = document.createElement("div");
          row.className = "flex items-center gap-3";

          var iconHtml =
            '<div class="w-9 h-9 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">' +
              '<i class="fas fa-mobile-alt text-blue-600 text-sm"></i>' +
            '</div>';

          var numHtml =
            '<div class="min-w-0 flex-1">' +
              '<div class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-0.5">' + label + '</div>' +
              '<div class="font-display font-extrabold text-xl text-gray-900 tracking-wide font-mono">' + (ph.masked || "") + '</div>' +
            '</div>';

          var waHtml = "";
          if (ph.whatsapp) {
            waHtml =
              '<span class="shrink-0 inline-flex items-center gap-1 text-[10px] font-bold text-green-700 bg-green-50 border border-green-200 px-2.5 py-1.5 rounded-full">' +
                '<i class="fab fa-whatsapp text-sm"></i>' +
                'WhatsApp' +
              '</span>';
          }

          row.innerHTML = iconHtml + numHtml + waHtml;
          container.appendChild(row);
        });
        show("p-phones-container");
      }
    } else if (data.found) {
      // Person found, but no direct mobile indexed — show contact header
      show("p-contact-header");
      show("p-no-phone");
      // If this was already a deep search, hide the button and update message
      var deepBtn = q("p-deep-search-btn");
      var deepMsg = q("p-no-phone-msg");
      if (data.deepSearch) {
        if (deepBtn) deepBtn.classList.add("hidden");
        if (deepMsg) deepMsg.textContent = "Deep search returned no direct mobile either. Try in your full account for the most complete coverage.";
      } else {
        if (deepBtn) deepBtn.classList.remove("hidden");
        if (deepMsg) deepMsg.textContent = "No direct mobile in standard index. Run a deep search to scan extended sources.";
      }
    } else {
      // Person not found at all — hide the empty contact header
      hide("p-contact-header");
      show("p-person-not-found");
    }

    show("phone-result");
  }

  // ── Email form ───────────────────────────────────────────────────────────────
  var emailForm = q("email-form");
  if (emailForm) {
    emailForm.addEventListener("submit", async function (e) {
      e.preventDefault();
      hide("email-error"); hide("email-result");
      setEmailLoading(true);

      var token = await getToken();
      if (!token) {
        show("email-error"); setText("email-error-msg", "Could not initialize demo. Please refresh.");
        setEmailLoading(false); return;
      }

      var fn = ((emailForm.querySelector("[name=emailFullName]") || {}).value || "").trim();
      var co = ((emailForm.querySelector("[name=companyOrDomain]") || {}).value || "").trim();

      if (!fn || !co) {
        show("email-error"); setText("email-error-msg", "Please enter both full name and company or domain.");
        setEmailLoading(false); return;
      }

      var cf = await getCfToken();
      var params = new URLSearchParams({ t: token, mode: "findEmail", fullName: fn, domain: co });
      if (cf) params.set("cf", cf);
      if (visitorId) params.set("fid", visitorId);

      try {
        var resp = await fetch(ENRICH_URL + "?" + params.toString());
        var json = await resp.json();

        if (resp.status === 403 && json && json.error === "bot_detected") {
          show("email-error"); setText("email-error-msg", "Security check failed. Please wait a moment and try again.");
        } else if (resp.status === 429 || resp.status === 402) {
          showRateLimit("email");
        } else if (resp.status === 401) {
          cachedToken = null; show("email-error"); setText("email-error-msg", "Session expired — please refresh the page and try again.");
        } else if (!resp.ok) {
          show("email-error"); setText("email-error-msg", "Search failed. Please try again in a few seconds.");
        } else {
          renderEmailResult(json);
        }
      } catch (_) {
        show("email-error"); setText("email-error-msg", "Network error — please check your connection and try again.");
      }
      resetTurnstile();
      setEmailLoading(false);
    });
  }

  function renderEmailResult(data) {
    var contact = data.contact || {};
    var name = contact.fullName || "—";
    var initials = name.split(" ").map(function(p){return(p[0]||"");}).join("").slice(0,2).toUpperCase() || "?";

    setText("e-avatar", initials);
    setText("e-name", name);
    setText("e-company", contact.company || "");

    if (data.credits && data.credits.emailsRemaining !== undefined) {
      setText("emails-remaining", data.credits.emailsRemaining);
    }

    hide("e-email-verified"); hide("e-email-probable"); hide("e-email-none");

    if (data.emailStatus === "verified" && data.email) {
      show("e-email-verified");
      setText("e-email-value", data.email);
    } else if (data.emailStatus === "probable" && data.email) {
      show("e-email-probable");
      setText("e-probable-value", data.email);
    } else {
      show("e-email-none");
    }

    show("email-result");
  }

  // ── Deep search button ───────────────────────────────────────────────────────
  document.addEventListener("click", function (e) {
    var btn = e.target.closest("#p-deep-search-btn");
    if (!btn || btn.disabled) return;

    var hint = phoneSearchHint || {};
    var name = hint.name || hint.guessedName || "";
    if (!name) return; // can't deep-search without a name

    var parts     = name.trim().split(/\s+/);
    var firstName = parts[0] || "";
    var lastName  = parts.slice(1).join(" ") || "";
    if (!firstName) return;

    // Detect country from LinkedIn URL subdomain (fr.linkedin.com → FR)
    var country = "";
    if (hint.linkedin) {
      var m = hint.linkedin.match(/^https?:\/\/([a-z]{2})\.linkedin\.com/i);
      if (m && m[1].toLowerCase() !== "www") country = m[1].toUpperCase();
    }

    var btnTxt = document.getElementById("p-deep-search-txt");
    btn.disabled = true;
    if (btnTxt) btnTxt.textContent = "Searching…";

    (async function () {
      var token = await getToken();
      if (!token) { btn.disabled = false; if (btnTxt) btnTxt.textContent = "Run deep search"; return; }

      var cf = await getCfToken();
      var params = new URLSearchParams({ t: token, mode: "deepSearch", firstName: firstName });
      if (lastName) params.set("lastName", lastName);
      if (country)  params.set("country",  country);
      if (cf)       params.set("cf", cf);
      if (visitorId) params.set("fid", visitorId);

      try {
        var resp = await fetch(ENRICH_URL + "?" + params.toString());
        var json = await resp.json();

        if (resp.status === 429 || resp.status === 402) {
          showRateLimit("phone");
          hide("phone-result");
        } else if (resp.ok) {
          renderPhoneResult(json);
        }
        // On error: leave existing result visible
      } catch (_) {}

      resetTurnstile();
      btn.disabled = false;
      if (btnTxt) btnTxt.textContent = "Run deep search";
    })();
  });

  // ── Rate limit — conversion-focused message ──────────────────────────────────
  function showRateLimit(type) {
    var errId  = type === "phone" ? "phone-error" : "email-error";
    var msgId  = type === "phone" ? "phone-error-msg" : "email-error-msg";
    var count  = type === "phone" ? "3 phones" : "90 emails";
    var errEl  = q(errId);
    var msgEl  = q(msgId);
    if (!errEl || !msgEl) return;
    errEl.classList.remove("hidden");
    // Swap icon color to amber (limit, not a real error)
    errEl.className = errEl.className.replace("bg-red-50 border-red-200 text-red-700", "bg-amber-50 border-amber-200 text-amber-800");
    var icon = errEl.querySelector("i");
    if (icon) { icon.className = "fas fa-rocket text-amber-400 shrink-0"; }
    msgEl.innerHTML =
      "<span class='font-bold'>Demo limit reached for today.</span> " +
      "Create a free account — " + count + " per month, no credit card needed. " +
      "<a href='https://app.datagma.com/register' class='underline font-bold text-blue-700 hover:text-blue-900'>Start free →</a>";
  }

  // ── "Try another method" buttons inside p-phone-none ────────────────────────
  document.addEventListener("click", function (e) {
    var btn = e.target.closest(".p-try-method");
    if (!btn) return;
    var mode = btn.dataset.mode;
    if (mode) {
      setPhoneSubtab(mode);
      hide("phone-result");
      // Scroll the form into view smoothly
      var form = q("phone-form");
      if (form) form.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  });

  // Prefetch token
  getToken();
})();
</script>

<style>
.phone-subtab, .main-tab { cursor: pointer; }
#p-phone-value { letter-spacing: 0.05em; }
</style>
