<script>
  (function () {
    var count = 14203;
    var els = [
      document.getElementById('live-phones-count'),
      document.getElementById('testimonial-counter'),
    ];
    function tick() {
      count += Math.floor(Math.random() * 3) + 1;
      var formatted = count.toLocaleString('en-US');
      els.forEach(function (el) { if (el) el.textContent = formatted; });
      setTimeout(tick, Math.floor(Math.random() * 8000) + 4000);
    }
    setTimeout(tick, 5000);
  })();
</script>
