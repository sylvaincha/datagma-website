---
import BaseLayout from "./BaseLayout.astro";
import "../styles/blog-fonts.css";
import "../styles/starlight/layers.css";
import "../styles/starlight/props.css";
import "../styles/starlight/reset.css";
import "../styles/starlight/util.css";
import "../styles/starlight/asides.css";
import "../styles/starlight/anchor-links.css";
import "../styles/starlight/markdown.css";
import "../styles/starlight/overrides.css";
import blogPostScriptUrl from "../scripts/blog-post.js?url";

const { title, description, canonical, robots, alternates, extraJsonLd } = Astro.props as {
  title: string;
  description?: string;
  canonical?: string;
  robots?: string;
  alternates?: Array<{ href: string; hreflang: string }>;
  extraJsonLd?: unknown[];
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  robots={robots}
  alternates={alternates}
  extraJsonLd={extraJsonLd}
  activeNav="blog"
>
  <main class="blog-root max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 sm:pt-28">
    <slot />
  </main>
  <script type="module" src={blogPostScriptUrl}></script>
</BaseLayout>

